# ==============================================================================
# .gitignore for Academic Claude Code Projects (Stata/Python/LaTeX)
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# Stata artifacts
*.smcl
*.gph

# OS files
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Project symlink (points to Dropbox folder)
# ---------------------------------------------------------------------------
# Ignore everything in project/ by default (data, output, figures, etc.)
project/**
# Un-ignore directories so git traverses the full tree
!project/**/
# Whitelist code files by extension
!project/**/*.do
!project/**/*.py
!project/**/*.R
!project/**/*.r
!project/**/*.tex
!project/**/*.bib
!project/**/*.sh
!project/**/*.sql
!project/**/*.jl
!project/**/*.m
!project/**/*.ipynb
!project/**/*.ado
!project/**/README.md

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

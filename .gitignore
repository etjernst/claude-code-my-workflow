# ==============================================================================
# .gitignore for Salty Water Project
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Script logs
scripts/logs/*.log

# Data (large/sensitive -- do not track)
data/**/*.csv
data/**/*.dta
data/**/*.xlsx
data/**/*.parquet

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

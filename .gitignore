# ==============================================================================
# .gitignore for Migration Returns Paper (CKT)
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Stata artifacts
*.smcl
scripts/logs/*.log
*.dta

# Data (large/sensitive -- do not track)
data/**/*.csv
data/**/*.dta
data/**/*.xlsx

# Python
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
